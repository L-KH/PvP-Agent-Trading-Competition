# ─────────────────────────────────────────────────────────────────────────────
# Battleground Alpha agent configuration.
# Copy this file to `.env` (copy .env.example .env) and fill in your values.
# Every value here can also be set as a real environment variable (env wins).
# ─────────────────────────────────────────────────────────────────────────────

# ── AUTH (required on first run) ─────────────────────────────────────────────
# Provide EITHER an access code (from https://t.me/creatorbid) OR a USER JWT
# copied from the dashboard. The access code is exchanged for a user JWT
# automatically. After the first successful run, identity is cached in
# .agent.json and credentials are no longer required.
BID_ACCESS_CODE=
# BID_USER_JWT=

# Optional: reuse a specific wallet instead of generating a fresh one.
# BID_PRIVATE_KEY=

# Optional cosmetic label / archetype tag.
# BID_AGENT_NAME=
BID_ARCHETYPE=Custom

# ── CHAIN (advanced — usually leave unset) ───────────────────────────────────
# /api/game advertises an RPC host that is Cloudflare-fronted and NOT reachable
# for JSON-RPC. The agent auto-probes and falls back to the raw node IP, so you
# normally don't need this. Pin it only if auto-detection ever fails:
# BID_RPC_URL=http://5.161.35.78:8545

# ── SAFETY ───────────────────────────────────────────────────────────────────
# DRY_RUN=1 -> exercises auth + polling + signals + logging but sends NO
# on-chain transactions. Test with 1 first; set 0 to trade live.
BID_DRY_RUN=1

# ── RISK / SIZING ────────────────────────────────────────────────────────────
# USDC per entry, and the self-imposed cumulative-buy cap per battle. Your
# Trading Safe is funded with your dashboard "Buy-in per game" (1-1000 USDC),
# so sizing is naturally bounded by the Safe balance. Keep these consistent
# with your dashboard buy-in.
BID_TRADE_SIZE_USDC=100
BID_BUY_CAP_USDC=1000

# ── STRATEGY ─────────────────────────────────────────────────────────────────
# "open_pump"    -> buy big at the open, ride the pump, fast exits (DEFAULT)
# "open_patient" -> buy SMALL at the open, NO hard stop; hold through dips and let the
#                   trailing stop capture the peak (captures pump-after-dip battles)
# "reversal"     -> buy confirmed bottoms after a dump, sell into the bounce
BID_STRATEGY=open_pump

# open_pump / open_patient knobs (the early-pump play — tokens rip ~3-5x then bleed):
BID_OPEN_BUY_USDC=1000         # open-buy size for open_pump (clamped to Safe => ~all-in)
BID_OPEN_PATIENT_BUY_USDC=50   # open-buy size for open_patient (smaller — no stop protection)
BID_OPEN_ENTRY_MIN_GR=150      # only open-buy while gameRemaining >= this (first ~30s)
BID_PUMP_TARGET_MULT=3.0       # hard take-profit at entry x this (home run)
BID_PUMP_TRAIL_ARM=1.2         # arm the trailing stop once price >= entry x this
BID_OPEN_TRAIL_PCT=0.12        # sell if price drops this far from the peak (tight = exit fast)
BID_OPEN_STOP_PCT=0.12         # cut if price falls this far below entry (failed pump)
BID_OPEN_EXIT_BY_GR=120        # backstop: exit the open play once gameRemaining <= this
BID_OPEN_REENTER=1             # 1 = also scalp later dips (multiple trades/battle); 0 = one open play only

# ── SIGNALS (used by both strategies) ────────────────────────────────────────
BID_MOMENTUM_WINDOW=30         # window for VWAP / volatility
BID_TRADES_LIMIT=100           # recent trades fetched each tick
BID_SHORT_WINDOW=5             # fast momentum / turn-detection window
BID_STRUCT_WINDOW=14           # swing-structure window (sweep + bottom detection)
BID_RSI_PERIOD=9               # RSI lookback (short = fast reaction)

# ── ENTRY: buy CONFIRMED reversals off the bottom (ICT sweep + MSS / RSI) ────
BID_FEE_PCT=0.003              # pool fee per side (feeTier 3000 = 0.3%)
BID_SLIPPAGE_PCT=0.01          # estimated slippage per side (thin pool)
BID_MIN_PROFIT_PCT=0.01        # take-profit must beat round-trip cost by this
BID_MIN_DRAWDOWN=0.06          # require a >=6% dump (liquidity sweep) before buying
BID_MIN_BOUNCE=0.0             # price >= this above the low (0 = off; RSI guards against chasing)
BID_RSI_BUY_MAX=48             # only buy when oversold (RSI below this)
BID_FLOW_MIN=0.0               # require non-negative buy pressure to enter
BID_MIN_ENTRY_MOMENTUM=0.0     # short momentum must be >= this (turning up)
BID_CONFIDENCE_THRESHOLD=0.35  # min composite score [0,1] (lower = MORE trades)

# ── EXIT: sell into strength + risk management ───────────────────────────────
BID_TAKE_PROFIT_PCT=0.05       # lock gains at +5% unrealized ("sell mid")
BID_STOP_LOSS_PCT=0.04         # cut losers at -4% unrealized
BID_TRAIL_ACTIVATE_PCT=0.03    # arm trailing stop once peak gain >= 3%
BID_TRAILING_STOP_PCT=0.015    # exit if price drops 1.5% from the peak

# ── TIMING ───────────────────────────────────────────────────────────────────
BID_EXIT_SECONDS=15            # flatten everything when gameRemaining < this
BID_NO_ENTRY_SECONDS=12        # stop opening new positions when remaining < this
BID_POLL_INTERVAL_S=0.6        # decide() cadence (faster reaction)
BID_LOSS_COOLDOWN_S=8          # pause new entries this long after a stop-loss
BID_HEARTBEAT_S=30             # liveness ping interval (must be <= 60)

# ── LOGGING ──────────────────────────────────────────────────────────────────
BID_LOG_LEVEL=INFO             # DEBUG for verbose per-tick signal output
